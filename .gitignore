# ==============================================================================
# SynAI - Professional .gitignore Configuration
# ==============================================================================

# ==============================================================================
# Development Tools & IDEs
# ==============================================================================

# Claude Code (AI Assistant) - Never commit AI development artifacts
.claude/
.claude.*

# Visual Studio Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

# JetBrains IDEs (WebStorm, IntelliJ, etc.)
.idea/
*.iws
*.iml
*.ipr

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim/Neovim
*.swp
*.swo
*.swn
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# ==============================================================================
# Node.js & Package Management
# ==============================================================================

# Dependencies
node_modules/
jspm_packages/
bower_components/

# Package manager files
package-lock.json
yarn.lock
pnpm-lock.yaml
.pnpm-store/
.yarn/
.pnp
.pnp.js
.pnp.cjs

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# ==============================================================================
# Build Output & Distribution
# ==============================================================================

# Vite
dist/
dist-ssr/
.vite/

# Build directories
build/
out/
public/build/

# TypeScript compilation
*.tsbuildinfo
.tscache/

# ==============================================================================
# Environment & Configuration
# ==============================================================================

# Environment variables
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# Local configuration files
*.local
config/local.json
config/production.json

# ==============================================================================
# Logs & Runtime Data
# ==============================================================================

# Log files
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov
.nyc_output

# ==============================================================================
# Testing & Quality Assurance
# ==============================================================================

# Test coverage
coverage/
.nyc_output
.coverage/
junit.xml
test-results/

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/

# Jest
jest-coverage/

# ==============================================================================
# Operating System Files
# ==============================================================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ==============================================================================
# Security & Sensitive Data
# ==============================================================================

# API keys and secrets
.secrets
secrets.json
*.key
*.pem
*.crt
*.p12

# Database files
*.db
*.sqlite
*.sqlite3

# ==============================================================================
# Temporary & Cache Files
# ==============================================================================

# Temporary folders
tmp/
temp/
.tmp/
.temp/

# Cache directories
.cache/
.parcel-cache/
.next/
.nuxt/
.vuepress/dist

# ==============================================================================
# Deployment & CI/CD
# ==============================================================================

# Vercel
.vercel
.vercel.json

# Netlify
.netlify

# Docker
Dockerfile.local
docker-compose.override.yml

# Kubernetes
*.local.yaml
*.local.yml

# ==============================================================================
# Miscellaneous
# ==============================================================================

# Editor backups
*~
*.orig
*.bak
*.tmp

# Archive files
*.zip
*.tar.gz
*.rar

# Dependency directories that might be created accidentally
**/node_modules/

